
{
  "manifest_version": 3,
  "name": "NexSpot",
  "version": "0.6.0",
  "description": "NexSpot with auto step navigation",
  "permissions": [
    "storage",
    "sidePanel",
    "tabs",
    "scripting",
    "activeTab",
    "webNavigation"
  ],
  "host_permissions": [
    "http://localhost:4000/*",
    "https://github.com/*",
    "https://www.figma.com/*",
    "https://www.notion.so/*"

  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open NexSpot"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}